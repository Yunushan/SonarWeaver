# Managed by SonarWeaver Ansible. Do not edit on the managed host.
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ sonarweaver_proxy_server_name }};

    ssl_certificate {{ _sonarweaver_proxy_tls_certificate }};
    ssl_certificate_key {{ _sonarweaver_proxy_tls_certificate_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    client_max_body_size {{ sonarweaver_proxy_client_max_body_size }};

    location / {
        proxy_pass {{ sonarweaver_proxy_upstream_url }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
