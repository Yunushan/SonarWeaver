# Rendered by SonarWeaver for a production namespace.
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: sonarweaver-default-deny
spec:
  podSelector: {}
  policyTypes:
    - Ingress
    - Egress
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: sonarweaver-sonarqube
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/instance: "@RELEASE@"
      app.kubernetes.io/name: sonarqube
  policyTypes:
    - Ingress
    - Egress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              sonarweaver.io/network-access: ingress
      ports:
        - protocol: TCP
          port: 9000
    - from:
        - namespaceSelector:
            matchLabels:
              sonarweaver.io/network-access: monitoring
      ports:
        - protocol: TCP
          port: 9000
  egress:
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53
    - to:
        - ipBlock:
            cidr: "@DATABASE_EGRESS_CIDR@"
      ports:
        - protocol: TCP
          port: 0 # @DATABASE_PORT@
