# Non-secret Docker Compose settings. Copy this file to .env.
SONARQUBE_IMAGE=sonarqube:26.7.0.124771-community
POSTGRES_IMAGE=postgres:18
SONAR_BIND_ADDRESS=127.0.0.1
SONAR_PORT=9000

# Replace these for production. The password stays in secrets/jdbc_password.
SONAR_JDBC_URL=jdbc:postgresql://postgresql.example.invalid:5432/sonarqube
SONAR_JDBC_USERNAME=sonarqube
