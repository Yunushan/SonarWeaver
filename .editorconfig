root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yaml,yml,json}]
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_style = space
indent_size = 2

[*.{ps1,psm1,psd1}]
indent_style = space
indent_size = 4

[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
